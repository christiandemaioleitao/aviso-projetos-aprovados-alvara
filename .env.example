# .env.example — copie para .env e preencha com seus valores reais.
# O .env NUNCA deve ser commitado (já está no .gitignore).

# Token do seu bot do Telegram (obtenha via @BotFather)
TELEGRAM_BOT_TOKEN=

# ID do chat/grupo que receberá as notificações.
# Para descobrir: envie uma mensagem ao bot e abra
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# (Opcional) Quantas threads em paralelo para verificar os projetos
MAX_WORKERS=6

# (Opcional) Timeout (em segundos) de cada requisição HTTP
FETCH_TIMEOUT=30

# (Opcional) Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# (Opcional) Modo dry-run — não envia Telegram, só loga
# DRY_RUN=1

# (Opcional) Filtrar projetos por ID (separados por vírgula)
# ONLY_IDS=19474,47847

# (Opcional) Tratar sempre como mudança (força refetch + reavaliação)
# FORCE=1
